# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartcity
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Gmail SMTP (use an App Password, not your account password)
GMAIL_USERNAME=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Public base URL embedded in email verification links
# Local dev: run `cloudflared tunnel --url http://localhost:8080` and paste the URL here
# Production: set to your public domain, e.g. https://api.yourdomain.com
APP_BASE_URL=https://your-public-url.example.com
