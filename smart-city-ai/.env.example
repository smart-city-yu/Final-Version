# NVIDIA API — used for both text LLM and image Nemotron
# Get a key at https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_key_here

# Text LLM model (Pass A + Pass C)
NVIDIA_TEXT_MODEL=meta/llama-3.1-8b-instruct

# Image analysis model (/detect endpoint)
NVIDIA_IMAGE_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
